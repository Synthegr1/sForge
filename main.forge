// This is an comment

branch Main{
    
    // Def project specs
    project sOS {
        arch _i386;
        out 'main';
        osdev = true;
        project_path = '/home/gabrielrebillat/Downloads/sOS-main';
        infos = false;
    }

    // Def objects (files) of the OS
    cat objects {
        asm boot = '/home/gabrielrebillat/Downloads/sOS-main/os/boot.asm'; 
        c kernel = '/home/gabrielrebillat/Downloads/sOS-main/os/kernel.c'; 
        c math = '/home/gabrielrebillat/Downloads/sOS-main/os/math.c';
        c util = '/home/gabrielrebillat/Downloads/sOS-main/os/util.c'; 
        c shell = '/home/gabrielrebillat/Downloads/sOS-main/os/shell.c'; 
        rs math_rs = '/home/gabrielrebillat/Downloads/sOS-main/rust/maths.rs'; 
        ld linker = '/home/gabrielrebillat/Downloads/sOS-main/os/linker.ld';
    }

    // Compile objects
    forge compile {
		boot.compile(o, boot);
		kernel.compile(o, no_std);
		shell.compile(o, no_std);
		util.compile(o, no_std);
		math.compile(o, no_std);
		math_rs.compile(o, no_std);
    }

    // Link linker.ld
    forge link {
        ld(linker); 
        trans(bin);
    }

    // Run with qemu
	    forge run {
        qemu();
    }
}
